# ============================================================
# نظام إدارة الأعمال العلمية — مؤسسة ساعي
# انسخ إلى .env (للتطوير) أو إلى Vercel Env Vars (للإنتاج)
# ============================================================

# ============================================================
# قاعدة البيانات (PostgreSQL، إلزامي)
# ============================================================
# تطوير محلي: استخدم `npx prisma dev` ثم انسخ DATABASE_URL من stdout
# إنتاج: Vercel Postgres / Neon / Supabase / Railway
# تنسيق: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/saei_scientific?schema=public"

# ============================================================
# NextAuth (إلزامي)
# ============================================================
# سرّ توقيع JWT — توليد قيمة آمنة:
#   openssl rand -base64 32
# في Vercel: Settings → Environment Variables → NEXTAUTH_SECRET
NEXTAUTH_SECRET="change-me-in-production-min-32-chars"

# URL القاعدي للتطبيق
# تطوير: http://localhost:3000
# إنتاج: https://your-domain.com (يجب أن يطابق Vercel domain أو الـcustom domain)
NEXTAUTH_URL="http://localhost:3000"

# ============================================================
# اختياري — تشغيل البريد للتذكيرات (لاحقاً)
# ============================================================
# RESEND_API_KEY=""
# RESEND_FROM="نظام ساعي <noreply@example.com>"
