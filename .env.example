# قاعدة البيانات (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/saei_scientific?schema=public"

# NextAuth — توليد سر آمن: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"
