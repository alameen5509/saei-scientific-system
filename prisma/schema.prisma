// نظام إدارة الأعمال العلمية — مؤسسة ساعي
// Prisma 7 — driver adapter (@prisma/adapter-pg) إلزامي
// كل الجداول tenantId="saei" + createdAt + updatedAt + indexes مناسبة

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// المستخدمون (NextAuth-compatible) + الأدوار
// ============================================================

model User {
  id        String   @id @default(cuid())
  tenantId  String   @default("saei")
  email     String   @unique
  name      String?
  password  String?
  image     String?
  role      UserRole @default(RESEARCHER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  researcher Researcher?
  reviewer   Reviewer?

  @@index([tenantId])
}

enum UserRole {
  ADMIN                  // مدير النظام
  RESEARCH_COORDINATOR   // منسق الأبحاث
  JOURNAL_COORDINATOR    // منسق المجلة
  RESEARCHER             // باحث
  REVIEWER               // محكم
}

// ============================================================
// الباحث — ملف موسّع لمستخدم بدور RESEARCHER
// ============================================================

model Researcher {
  id            String   @id @default(cuid())
  tenantId      String   @default("saei")
  userId        String   @unique
  displayName   String
  academicTitle String?
  specialty     String?
  bio           String?
  joinedAt      DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  works ScientificWork[] @relation("WorkOwner")

  @@index([tenantId])
}

// ============================================================
// المراجع — ملف موسّع لمستخدم بدور REVIEWER
// ============================================================

model Reviewer {
  id        String   @id @default(cuid())
  tenantId  String   @default("saei")
  userId    String   @unique
  expertise String?
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews Review[]

  @@index([tenantId])
}

// ============================================================
// مراحل سير العمل — جدول مرجعي قابل للتوسعة
// ============================================================

model WorkflowStage {
  id        String   @id @default(cuid())
  tenantId  String   @default("saei")
  code      String   @unique
  label     String
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  works ScientificWork[]

  @@index([tenantId])
}

// ============================================================
// الأعمال العلمية — الكيان المركزي
// ============================================================

model ScientificWork {
  id           String    @id @default(cuid())
  tenantId     String    @default("saei")
  code         String    @unique
  title        String
  specialty    String
  track        WorkTrack
  researcherId String
  stageCode    String
  progress     Int       @default(0)
  startedAt    DateTime
  deadline     DateTime
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  researcher Researcher    @relation("WorkOwner", fields: [researcherId], references: [id], onDelete: Restrict)
  stage      WorkflowStage @relation(fields: [stageCode], references: [code])
  reviews    Review[]

  @@index([tenantId])
  @@index([researcherId])
  @@index([stageCode])
  @@index([track])
  @@index([deadline])
}

enum WorkTrack {
  BOOK
  JOURNAL
  THESIS
  ARTICLE
}

// ============================================================
// المراجعات — تقييم العمل من قِبل مراجع
// ============================================================

model Review {
  id         String       @id @default(cuid())
  tenantId   String       @default("saei")
  workId     String
  reviewerId String
  status     ReviewStatus @default(PENDING)
  rating     Int?
  comments   String?
  submittedAt DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  work     ScientificWork @relation(fields: [workId], references: [id], onDelete: Cascade)
  reviewer Reviewer       @relation(fields: [reviewerId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([workId])
  @@index([reviewerId])
  @@index([status])
}

enum ReviewStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  NEEDS_REVISION
}
